# direnv — fetches dev secrets from Cloud Secret Manager at shell entry
# Run: direnv allow
export FIREBASE_SERVICE_ACCOUNT_KEY=$(gcloud secrets versions access latest --secret="firebase-service-account-dev" --project="shoplift-dev" 2>/dev/null)
export IYZICO_API_KEY=$(gcloud secrets versions access latest --secret="iyzico-api-key-dev" --project="shoplift-dev" 2>/dev/null)
export IYZICO_SECRET_KEY=$(gcloud secrets versions access latest --secret="iyzico-secret-key-dev" --project="shoplift-dev" 2>/dev/null)
export FLUTTERWAVE_SECRET_KEY=$(gcloud secrets versions access latest --secret="flutterwave-secret-key-dev" --project="shoplift-dev" 2>/dev/null)
export TWILIO_AUTH_TOKEN=$(gcloud secrets versions access latest --secret="twilio-auth-token-dev" --project="shoplift-dev" 2>/dev/null)
export RESEND_API_KEY=$(gcloud secrets versions access latest --secret="resend-api-key-dev" --project="shoplift-dev" 2>/dev/null)
export GROQ_API_KEY=$(gcloud secrets versions access latest --secret="groq-api-key-dev" --project="shoplift-dev" 2>/dev/null)
export SUPABASE_URL=$(gcloud secrets versions access latest --secret="supabase-url-dev" --project="shoplift-dev" 2>/dev/null)
export SUPABASE_SERVICE_ROLE_KEY=$(gcloud secrets versions access latest --secret="supabase-service-role-key-dev" --project="shoplift-dev" 2>/dev/null)

# Always default to dev Firebase project
firebase use dev 2>/dev/null

# Apple Silicon Docker fix
export DOCKER_DEFAULT_PLATFORM=linux/amd64