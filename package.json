{
  "name": "monorepo",
  "private": true,
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:rules": "firebase emulators:exec --only firestore \"jest infra/firestore\"",
    "test:smoke": "echo 'Skipping smoke tests for now'",
    "lint": "turbo run lint",
    "prepare": "husky",
    "emulator": "firebase emulators:start --import=./infra/emulator/seed-data --export-on-exit=./infra/emulator/seed-data",
    "seed": "npx tsx infra/emulator/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@shoplift/types": "^0.0.1",
    "lucide-react": "^0.577.0",
    "tailwind": "^2.3.1",
    "tailwindcss": "^4.2.2"
  }
}
